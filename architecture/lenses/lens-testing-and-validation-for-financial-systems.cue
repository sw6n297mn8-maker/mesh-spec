limitations: [
	{
		description: "Property-based testing finds edge cases but doesn't guarantee complete coverage — generator may miss certain input distributions."
		alternative: "Combine PBT with: explicit edge case catalog (known problematic values), mutation testing (verify test quality), and production reconciliation (catch what tests miss). No single technique is sufficient; layered approach covers gaps."
		rationale: "PBT is probabilistic, not exhaustive. Layered testing: PBT catches random edges, catalog catches known edges, reconciliation catches production edges."
	},
	{
		description: "Shadow mode for scoring requires 2x compute (both models score every operation) and sufficient operation volume for meaningful comparison."
		alternative: "Shadow mode duration: proportional to volume. High volume (100 ops/day): 1-2 weeks sufficient. Low volume (10 ops/day): 4-6 weeks. If volume too low for shadow: extend backtesting with bootstrap sampling to simulate more scenarios."
		rationale: "Statistical significance requires volume. Low volume: extend duration or supplement with backtesting."
	},
	{
		description: "Continuous reconciliation (every 15 min) creates database load — aggregation queries on ledger table compete with operational queries."
		alternative: "Reconciliation on read replica (not primary). Or: materialized view refreshed periodically (eventual — 15 min delay acceptable). Or: event-sourced balance maintained incrementally (no full table scan needed)."
		rationale: "Reconciliation must not degrade operational performance. Read replica or materialized view: isolation."
	},
	{
		description: "Contract testing between BCs requires organizational discipline — every consumer must register expectations, every schema change must check contracts."
		alternative: "CI enforcement: PR that modifies event schema → automated check against registered consumer contracts. Without consumer contract: warning (not block — consumer may not have registered yet). Over time: contract coverage tracked as metric, target >90%."
		rationale: "Contract testing is cultural as much as technical. CI enforcement + coverage metric: drives adoption without blocking velocity."
	},
	{
