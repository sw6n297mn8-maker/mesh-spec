		"a decisão envolve como garantir que mudanças em código não introduzem erros financeiros em caminhos existentes",
		"a decisão envolve como projetar property-based testing para invariantes financeiras (soma de débitos = soma de créditos)",
		"a decisão envolve como projetar contract testing entre bounded contexts para garantir compatibilidade de interfaces",
		"a decisão envolve como validar edge cases financeiros (arredondamento, overflow, moeda, timezone, dias úteis)",
		"a decisão envolve como fazer chaos engineering e failure injection em sistema financeiro sem risco real",
		"a decisão envolve que nível de cobertura e que tipos de teste são adequados para cada camada do sistema",
	]
	keywords: [
		"teste", "test", "testing", "validação", "validation",
		"reconciliação", "reconciliation", "batimento", "conferência",
		"property-based", "invariante", "invariant", "propriedade",
		"contract test", "consumer-driven", "Pact", "schema compatibility",
		"arredondamento", "rounding", "centavo", "penny", "precision",
		"chaos engineering", "failure injection", "fault tolerance",
		"regression", "regressão", "golden file", "snapshot",
		"ground truth", "backtesting", "shadow mode", "champion-challenger",
		"coverage", "cobertura", "mutation testing",
		"end-to-end", "e2e", "integration", "unit",
		"idempotência", "idempotency", "retry", "duplicate",
		"settlement", "liquidação", "conciliação",
	]
	excludeWhen: [
		"a decisão é sobre observability e detecção de problemas em produção — usar observability-operational-intelligence",
		"a decisão é sobre dívida técnica e qualidade de código — usar technical-debt-as-strategic-instrument",
		"a decisão é sobre design de ML models e training — usar ml-ai-systems-design",
		"a decisão é sobre isolamento de dados entre tenants — usar multi-tenancy-and-identity-architecture",
