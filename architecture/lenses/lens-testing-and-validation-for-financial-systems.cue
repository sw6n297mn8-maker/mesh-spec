testingAndValidationForFinancialSystems: artifact_schemas.#AnalyticalLens & {
id:     "lens-testing-and-validation-for-financial-systems"
name:   "Testing e Validação para Sistemas Financeiros"

purpose: "Orientar decisões sobre como testar sistemas financeiros com rigor — property-based testing, reconciliação contínua, chaos testing e validação de invariantes financeiras."
status: "draft"

trigger: {
	conditions: [
		"a decisão envolve como provar que dinheiro se move corretamente — somas batem, centavos não se perdem, saldos são consistentes",
