#!/usr/bin/env bash
set -euo pipefail

# pre-commit — Hook que bloqueia commit se README.md estiver stale
# em relação ao source canônico governance/readme/config.cue.
#
# Fluxo (per ADR-051):
#   1. Roda check-readme-coevolution.sh em modo check.
#   2. Se algum dos checks falhar, bloqueia commit com mensagem
#      indicando ação corretiva.
#
# README.md é artefato derivado full-file (per ADR-051). Regeneração
# é comando explícito documentado em governance/repo-structure.cue
# derivedArtifacts: 'generator > path'. O hook não auto-regenera.
#
# Instalação: git config core.hooksPath scripts/hooks

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || {
    echo "FAIL: não foi possível localizar a raiz do repo via git."
    exit 1
}

SCRIPT="$REPO_ROOT/scripts/ci/check-readme-coevolution.sh"
README="$REPO_ROOT/README.md"

if [ ! -f "$README" ]; then
    echo "FAIL: README.md não encontrado."
    exit 1
fi

if [ ! -x "$SCRIPT" ]; then
    echo "FAIL: $SCRIPT não encontrado ou não executável."
    exit 1
fi

cd "$REPO_ROOT"
if ! "$SCRIPT"; then
    echo ""
    echo "══════════════════════════════════════════════════════════════"
    echo "  Commit bloqueado: README derivado ou tree.entries inconsistentes."
    echo ""
    echo "  Corrija os findings acima no source canônico:"
    echo "    • governance/readme/config.cue"
    echo "    • filesystem governado do repo"
    echo ""
    echo "  Se o problema for README stale, regenere com:"
    echo "    cue export ./governance/readme -e output --out text > README.md"
    echo "══════════════════════════════════════════════════════════════"
    exit 1
fi
